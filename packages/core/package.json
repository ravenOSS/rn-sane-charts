{
  "name": "@rn-sane-charts/core",
  "version": "0.1.0",
  "description": "Deterministic chart math, scales, and layout for @rn-sane-charts/rn",
  "react-native": "./src/index.ts",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "react-native": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": ["src", "dist"],
  "sideEffects": false,
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "prepublishOnly": "pnpm run build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ravenOSS/rn-sane-charts.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/ravenOSS/rn-sane-charts/issues"
  },
  "homepage": "https://github.com/ravenOSS/rn-sane-charts/tree/main/packages/core",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "keywords": ["charting", "library"],
  "author": "David Richards",
  "license": "MIT",
  "packageManager": "pnpm@10.28.1",
  "devDependencies": {
    "@types/node": "^25.0.10",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "d3-array": "^3.2.4",
    "d3-format": "^3.1.2",
    "d3-scale": "^4.0.2",
    "d3-shape": "^3.2.0",
    "d3-time-format": "^4.1.0"
  }
}
